{
  "name": "epochs",
  "version": "0.33.0",
  "description": "Epochs — a digital strategy game of empires that rise and fall across seven epochs, played against AI opponents.",
  "author": "bronty13",
  "license": "UNLICENSED",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:web": "vite src/renderer",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "gen:data": "node scripts/build-data.mjs",
    "dist:mac": "electron-vite build && electron-builder --mac --dir"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.phantomlives.epochs",
    "productName": "Epochs",
    "directories": { "output": "dist" },
    "files": ["out/**/*"],
    "mac": {
      "target": "dir",
      "icon": "build/icon.icns",
      "category": "public.app-category.strategy-games"
    }
  }
}

.form-field textarea { vertical-align: middle; }

.form-field input[type=3D"checkbox"] + label { margin: 0px 0px 0px 10px; }

.form-field.required > label::after { content: "*"; color: rgb(255, 0, 0); =
margin-left: 2px; }

.form-field p { color: rgb(102, 102, 102); font-size: 12px; margin: 5px 0px=
; }

[data-loading=3D"true"] input, [data-loading=3D"true"] textarea { backgroun=
d: url("/hc/theming_assets/01HZH1Y8GB1P8M56C2ZBR4M4WG") 99% 50% / 16px 16px=

x solid rgb(221, 221, 221); border-radius: 4px; padding: 8px 30px 8px 10px;=
 outline: none; color: rgb(85, 85, 85); width: 100%; }

select:focus { border: 1px solid rgb(98, 29, 120); }

textarea { border: 1px solid rgb(221, 221, 221); border-radius: 2px; resize=
: vertical; width: 100%; outline: none; padding: 10px; }

textarea:focus { border: 1px solid rgb(98, 29, 120); }

.container { max-width: 1050px; margin: 0px auto; background-color: rgb(255=
, 255, 255); border-radius: 7px; padding: 20px !important; }

@media (min-width: 1050px) {
  .container { padding: 0px; width: 90%; }
}

.container-divider { margin-bottom: 20px; }

ul { list-style: none; margin: 0px; padding: 0px; }

.error-page { max-width: 1050px; margin: 0px auto; padding: 0px 5%; }

@media (min-width: 1050px) {

@charset "utf-8";

* { box-sizing: border-box; }

body { color: rgb(51, 51, 51); font-family: -apple-system, BlinkMacSystemFo=
nt, "Segoe UI", Helvetica, Arial, sans-serif; font-size: 15px; font-weight:=

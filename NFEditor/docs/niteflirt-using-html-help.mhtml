a { color: rgb(0, 102, 204); text-decoration: none; }

a:hover, a:active, a:focus { text-decoration: underline; }

input, textarea { color: rgb(0, 0, 0); font-size: 14px; }

input { font-weight: 300; max-width: 100%; box-sizing: border-box; outline:=
 none; transition: border 0.12s ease-in-out; }

input:focus { border: 1px solid rgb(98, 29, 120); }

input[disabled] { background-color: rgb(221, 221, 221); }

select { appearance: none; background: url("/hc/theming_assets/01HZH1Y8MXGM=

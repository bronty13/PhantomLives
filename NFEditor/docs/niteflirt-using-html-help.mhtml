.dropdown-toggle::after { color: inherit; }

.button, [role=3D"button"] { border: 1px solid rgb(98, 29, 120); border-rad=
ius: 4px; color: rgb(98, 29, 120); cursor: pointer; display: inline-block; =
font-size: 12px; line-height: 2.34; margin: 0px; padding: 0px 20px; text-al=
ign: center; transition: background-color 0.12s ease-in-out, border-color 0=
.12s ease-in-out, color 0.15s ease-in-out; user-select: none; white-space: =
nowrap; width: 100%; }

@media (min-width: 768px) {
  .button, [role=3D"button"] { width: auto; }
}

.button::after, [role=3D"button"]::after { color: rgb(98, 29, 120); }

.button:hover, .button:active, .button:focus, .button[aria-selected=3D"true=
"], [role=3D"button"]:hover, [role=3D"button"]:active, [role=3D"button"]:fo=
cus, [role=3D"button"][aria-selected=3D"true"] { background-color: rgb(98, =
29, 120); color: rgb(255, 255, 255); text-decoration: none; }

.button[aria-selected=3D"true"]:hover, .button[aria-selected=3D"true"]:focu=
s, .button[aria-selected=3D"true"]:active, [role=3D"button"][aria-selected=
=3D"true"]:hover, [role=3D"button"][aria-selected=3D"true"]:focus, [role=3D=
"button"][aria-selected=3D"true"]:active { background-color: rgb(31, 9, 38)=
; border-color: rgb(31, 9, 38); }

.button[data-disabled], [role=3D"button"][data-disabled] { cursor: default;=
 }

.button-large, input[type=3D"submit"] { background-color: rgb(98, 29, 120);=
 border: 0px; border-radius: 4px; color: rgb(255, 255, 255); font-size: 14p=
x; font-weight: 400; line-height: 2.72; min-width: 190px; padding: 0px 1.92=
86em; width: 100%; }

@media (min-width: 768px) {
  .button-large, input[type=3D"submit"] { width: auto; }
}

.button-large:hover, .button-large:active, .button-large:focus, input[type=
=3D"submit"]:hover, input[type=3D"submit"]:active, input[type=3D"submit"]:f=
ocus { background-color: rgb(31, 9, 38); }

.button-large[disabled], input[type=3D"submit"][disabled] { background-colo=
r: rgb(221, 221, 221); }

.button-secondary { color: rgb(102, 102, 102); border: 1px solid rgb(221, 2=
21, 221); background-color: transparent; }

.button-secondary:hover, .button-secondary:focus, .button-secondary:active =
{ color: rgb(51, 51, 51); border: 1px solid rgb(221, 221, 221); background-=
color: rgb(220, 220, 220); }

.table { width: 100%; table-layout: fixed; }

@media (min-width: 768px) {
  .table { table-layout: auto; }
}

.table th, .table th a { color: rgb(102, 102, 102); font-size: 13px; font-w=
eight: 300; text-align: left; }

[dir=3D"rtl"] .table th, [dir=3D"rtl"] .table th a { text-align: right; }

.table tr { border-bottom: 1px solid rgb(221, 221, 221); display: block; pa=
dding: 20px 0px; }

@media (min-width: 768px) {
  .table tr { display: table-row; }
}

.table td { display: block; }

@media (min-width: 768px) {
  .table td { display: table-cell; }
}

@media (min-width: 1024px) {
  .table td, .table th { padding: 20px 30px; }
}

@media (min-width: 768px) {
  .table td, .table th { padding: 10px 20px; height: 60px; }
}

.form { max-width: 650px; }

.form-field ~ .form-field { margin-top: 25px; }

.form-field label { display: block; font-size: 13px; margin-bottom: 5px; }

.form-field input { border: 1px solid rgb(221, 221, 221); border-radius: 4p=
x; padding: 10px; width: 100%; }

.form-field input:focus { border: 1px solid rgb(98, 29, 120); }

.form-field input[type=3D"text"] { border: 1px solid rgb(221, 221, 221); bo=
rder-radius: 4px; }

.form-field input[type=3D"text"]:focus { border: 1px solid rgb(98, 29, 120)=
; }

.form-field input[type=3D"checkbox"] { width: auto; }

.form-field .nesty-input { border-radius: 4px; height: 40px; line-height: 4=
0px; outline: none; vertical-align: middle; }

.form-field .nesty-input:focus { border: 1px solid rgb(98, 29, 120); text-d=
ecoration: none; }

.form-field .hc-multiselect-toggle:focus { outline: none; border: 1px solid=

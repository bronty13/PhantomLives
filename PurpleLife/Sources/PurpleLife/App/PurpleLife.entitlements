<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      Personal-use local app — sandbox dropped on purpose, mirroring Timeliner.

      PurpleLife reads / writes user-chosen paths under ~/Downloads (backup
      zips, exports) and the standard Application Support directory (sqlite,
      settings.json, attachments). It uses FileManager string paths, not
      security-scoped URL bookmarks, so the file API needs whatever the
      logged-in user can see.

      iCloud + CloudKit entitlements are NOT added in Phase 1 — they get
      wired in for Phase 4 (CloudKit E2E sync) once the spike at
      Spike/CloudKit/SPIKE.md PASSes.
    -->
</dict>
</plist>

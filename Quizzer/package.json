{
  "name": "quizzer",
  "version": "0.1.0",
  "private": true,
  "description": "Lightweight, portable quiz creator/customizer SPA that deploys self-contained, offline, branded quizzes to any browser.",
  "type": "module",
  "scripts": {
    "build:player": "vite build --config vite.player.config.ts",
    "embed:player": "node scripts/embed-player.mjs",
    "build:creator": "vite build",
    "build": "npm run build:player && npm run embed:player && npm run build:creator",
    "dev": "node scripts/ensure-player.mjs && vite",
    "dev:player": "vite --config vite.player.config.ts",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tiptap/pm": "^2.10.3",
    "@tiptap/react": "^2.10.3",
    "@tiptap/starter-kit": "^2.10.3",
    "dompurify": "^3.2.3",
    "idb": "^8.0.0",
    "jspdf": "^2.5.2",
    "jszip": "^3.10.1",
    "nanoid": "^5.0.9",
    "react": "^18.3.1",
    "react-colorful": "^5.6.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vite-plugin-singlefile": "^2.0.3",
    "vitest": "^2.1.8"
  }
}

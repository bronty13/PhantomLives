{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SideMolly",
  "version": "0.14.0",
  "identifier": "com.phantomlives.sidemolly",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SideMolly",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "shortDescription": "Molly bundle workbench",
    "longDescription": "SideMolly — the outbound counterpart to Molly's bundler. Verifies, extracts, edits, processes, and posts Molly bundles, then sends a post-report ZIP back to Molly to close the loop.",
    "copyright": "© 2026 Robert Olen",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/fonts/PaperDaisy.ttf"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/bronty13/PhantomLives/releases/latest/download/sidemolly-latest.json"
      ],
      "pubkey": "PLACEHOLDER_REPLACE_WITH_REAL_MINISIGN_PUBKEY_BEFORE_FIRST_RELEASE"
    }
  }
}

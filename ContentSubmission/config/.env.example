# Slack tokens for ContentSubmission.
#
# install.sh writes the canonical copy of this file to
# ~/.config/content-submission/.env with chmod 600. The .env file should
# NEVER be committed (it's already in .gitignore).
#
# Bot User OAuth Token  — api.slack.com/apps → Install App page
SLACK_BOT_TOKEN=xoxb-replace-me
#
# App-Level Token       — api.slack.com/apps → Basic Information →
#                         App-Level Tokens (scope: connections:write)
SLACK_APP_TOKEN=xapp-replace-me

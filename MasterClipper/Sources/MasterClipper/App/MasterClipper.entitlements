<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!--
      Personal-use local app — sandbox dropped on purpose.

      The file-audit feature reads / writes paths under
      `~/Dropbox/Sallie Content/Clips` and `/Volumes/PRO-G40/...`
      (FCP project drive), and uses `FileManager.fileExists(atPath:)`
      with string paths (not security-scoped URLs). Under the sandbox
      with `com.apple.security.files.user-selected.read-write`, those
      checks fail silently because string paths don't carry the
      bookmarked-URL grant — the audit row stays in error even after
      the user picks the right folder. Dropping the sandbox lets every
      file API see whatever the logged-in user can.

      Network client stays in so Ollama on http://localhost:11434
      remains reachable.
    -->
    <key>com.apple.security.network.client</key>
    <true/>
</dict>
</plist>

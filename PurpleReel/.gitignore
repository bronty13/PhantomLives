# Build artifacts
PurpleReel.app/
build/
.build/

# Help docs are staged into Resources/ at build time from the
# repo-root .md files. Bundled into the .app for offline access via
# HelpDocs; canonical copy lives at the repo root.
Sources/PurpleReel/Resources/Help/

# Apple Help Book bundle is generated from the .md docs by
# Scripts/generate-help-book.swift on every build; .helpindex is
# regenerated by hiutil. Both checked-in copies would just churn
# alongside every commit, so ignore the generated tree entirely.
Sources/PurpleReel/Resources/PurpleReel.help/


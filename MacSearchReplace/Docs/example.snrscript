{
  "version": 1,
  "name": "Example: rename TODO(old) → TODO(new) in Swift sources",
  "roots": ["."],
  "include": ["*.swift"],
  "exclude": [".build/**", "Pods/**"],
  "honorGitignore": true,
  "followSymlinks": false,
  "steps": [
    {
      "type": "literal",
      "search": "TODO(old)",
      "replace": "TODO(new)",
      "caseInsensitive": false,
      "multiline": false,
      "counter": false,
      "interpolatePathTokens": false
    }
  ]
}

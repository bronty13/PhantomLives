{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Molly",
  "version": "0.2.1",
  "identifier": "com.phantomlives.molly",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Molly",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "shortDescription": "Content creator central hub",
    "longDescription": "Molly — central hub for tracking personas, clips, schedules, customers, income and expenses across a content creator's work.",
    "copyright": "© 2026 Robert Olen",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/bronty13/PhantomLives/releases/latest/download/latest.json"
      ],
      "pubkey": "REPLACE_WITH_UPDATER_PUBLIC_KEY_BEFORE_PHASE5"
    }
  }
}

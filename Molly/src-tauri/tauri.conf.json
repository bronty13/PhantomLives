{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Molly",
  "version": "1.28.1",
  "identifier": "com.phantomlives.molly",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Molly",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "category": "Productivity",
    "shortDescription": "Content creator central hub",
    "longDescription": "Molly — central hub for tracking personas, clips, schedules, customers, income and expenses across a content creator's work.",
    "copyright": "© 2026 Robert Olen",
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/atw-bot/repost.js",
      "resources/atw-bot/package.json",
      "resources/atw-bot/VERSION"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/bronty13/PhantomLives/releases/download/molly-updater-feed/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY5ODRDNzUxREE4ODFCMTEKUldRUkc0amFVY2VFK1M2cS9QODY0Smtzem42eVJueW1YRG82Tzg0OE1zN0liZ1ZzdnZPVGdheTUK"
    }
  }
}

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- v1 ships non-sandboxed (Developer ID), so PurpleMark can open and save
         markdown files anywhere the user points it. App Store sandboxing is a
         phase-2 concern. -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
</dict>
</plist>
